{
    "dataset": "dataego",
    "modality": ["RGB", "Gyro", "Acce"],
    "model_name": "tbn_lwf",
    
    "backbone": "tbn",
    "arch": "BNInception",
    "fusion_type": "concat",
    "consensus_type": "avg",
    "before_softmax": true,
    
    "train_list": "dataego_train.txt",
    "test_list": "dataego_test.txt",
    "mpu_path": "./datasets/DataEgo/sensor/",
    
    "num_segments": 8,
    "batch_size": 8,
    "workers": 4,
    "dropout": 0.5,
    
    "lr": 0.001,
    "lr_steps": [10, 20],
    "momentum": 0.9,
    "weight_decay": 0.0005,
    "epochs": 50, 
    "clip_gradient": 20,
    
    "memory_size": 0,
    "increment": 10,
    "shuffle": false,
    
    "partialbn": true,
    "freeze": false,
    
    "mode": "train",
    "enable_ood": false,
    "ood_methods": ["MSP", "ODIN", "Energy", "LTS_Individual", "LTS_Fusion", "LTS_RGB_Only", "LTS_Gyro_Only", "LTS_Acce_Only", "LTS_Late_Fusion"],
    "weights_path": "null",
  
    "seed": 1993,
    "device": [0],
    "prefix": "mmea-owcl",
    "log_test_acc": false,
    "use_wandb": true,
    "debug_mode": false
  }
