{
    "dataset": "dataego",
    "modality": ["RGB", "Gyro", "Acce"],
    "model_name": "tbn_mmeader",
    "exemplar_selection": "reservoir",
    
    "backbone": "tbn",
    "arch": "BNInception",
    "fusion_type": "auxiliary_head_v2_7",
    "consensus_type": "avg",
    "before_softmax": true,
    
    "train_list": "dataego_train.txt",
    "test_list": "dataego_test.txt",
    "mpu_path": "./datasets/DataEgo/sensor/",
    
    "num_segments": 8,
    "batch_size": 8,
    "workers": 4,
    "dropout": 0.5,
    
    "lr": 0.001,
    "lr_steps": [10, 20],
    "momentum": 0.9,
    "weight_decay": 0.0005,
    "epochs": 50, 
    "clip_gradient": 20,
    
    "memory_size": 320,
    "increment": 5,
    "shuffle": false,
    
    "pretrain_epochs": 50,
    "confidence_method": "energy",
    "aux_loss_weight": 0.3,
    "partialbn": true,
    "freeze": false,
    
    "mode": "train",
    "enable_ood": false,
    "ood_methods": ["MSP", "Energy"],
    "weights_path": "",
  
    "seed": 1993,
    "device": [0],
    "prefix": "mmea-owcl",
    "log_test_acc": false,
    "use_wandb": true,
    "debug_mode": false,

    "mmeader_alpha": 0.2
}

