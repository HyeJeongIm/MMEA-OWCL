{
  "dataset": "mmea",
  "modality": ["RGB", "Gyro", "Acce"],
  "model_name": "tbn_derpp",
    "exemplar_selection": "reservoir",
  
  "backbone": "tbn",
  "arch": "BNInception",
  "fusion_type": "concat",
  "consensus_type": "avg",
  "before_softmax": true,
  
  "train_list": "mydataset_total_train.txt",
  "test_list": "mydataset_test.txt",
  "mpu_path": "./datasets/UESTC-MMEA-CL/mpu/",
  
  "num_segments": 8,
  "batch_size": 8,
  "workers": 4,
  "dropout": 0.5,
  
  "lr": 0.001,
  "lr_steps": [10, 20],
  "momentum": 0.9,
  "weight_decay": 0.0005,
  "epochs": 50, 
  "clip_gradient": 20,
  
  "memory_size": 320,
  "increment": 4,
  "shuffle": false,
  
  "pretrain_epochs": 10,
  "partialbn": true,
  "freeze": false,
  
  "mode": "train",
  "enable_ood": false,
  "ood_methods": [
    "MSP_Baseline",
    "Energy_Baseline",
    "ReAct_Baseline",
    "Scale_Baseline", 
    "ASH_S_Baseline",
    "ODIN_Baseline",
    "Entropy_Baseline",
    "LTS_Baseline",
    "MaxLogit_Baseline"
  ],
  "weights_path": "",
  
  "seed": 1993,
  "device": [0],
  "prefix": "mmea-owcl",
  "log_test_acc": false,
    "use_wandb": true,
    "debug_mode": false,

    "der_alpha": 0.5,
    "der_beta": 0.5
}