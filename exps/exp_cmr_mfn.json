{
  "dataset": "mmea-tsn",
  "modality": ["RGB"],
  "model_name": "cmr_mfn",
  
  "backbone": "tsn",
  "arch": "ViT",
  "fusion_type": "attention",
  
  "train_list": "mydataset_total_train.txt",
  "test_list": "mydataset_test.txt",
